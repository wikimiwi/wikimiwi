<section class="section grid fade-in">
  <div class="card">
    <h3>Missão</h3>
    <p>Oferecer soluções eficientes e inovadoras.</p>
  </div>

  <div class="card">
    <h3>Visão</h3>
    <p>Ser referência em serviços de TI.</p>
  </div>

  <div class="card">
    <h3>Valores</h3>
