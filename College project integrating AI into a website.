  background: #ffffff;
  border-radius: 20px;
  border: 1px solid #e3ecf9;
  padding: 24px;
  box-shadow: 0 14px 30px rgba(8, 30, 67, 0.08);
}

.service-showcase .service-slider {
  min-height: 230px;
}

.service-showcase .service-card {
  display: none;
}

.service-showcase .service-card.active {
  display: block;
}

.service-showcase .service-card h3 {
  margin-top: 0;
  color: #0f2140;
}

.service-showcase .service-card p {
  color: #5a6b8a;
  line-height: 1.6;
}

.service-showcase .service-controls {
