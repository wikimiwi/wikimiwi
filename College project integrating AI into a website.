  line-height: 1.75;
  margin-bottom: 20px;
}

.service-home-text ul {
  list-style: disc;
  padding-left: 20px;
  color: #415981;
  margin: 0;
}

.service-home-text li {
  margin-bottom: 10px;
}

@media (max-width: 900px) {
  .service-home-container {
    grid-template-columns: 1fr;
  }
}

.logo-carousel h2 {
  margin-bottom: 28px;
  color: #113069;
}

.carousel-wrapper {
  overflow: hidden;
  padding: 0 10px;
}

.carousel-track {
  display: flex;
  gap: 20px;
  animation: slideLeft 16s linear infinite;
}

.carousel-item {
  flex: 0 0 auto;
  width: 180px;
  height: 100px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: transparent;
  border-radius: 18px;
  box-shadow: 0 4px 12px rgba(17, 41, 86, 0.12);
  border: 1px solid transparent;
}

.carousel-item img {
  max-width: 90%;
  max-height: 70%;
  object-fit: contain;
}

@keyframes slideLeft {
  0% { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}

.newsletter input {
  padding: 12px 14px;
  border-radius: 8px;
  border: 1px solid #cbe1f9;
  min-width: 220px;
}

.newsletter button {
  padding: 12px 20px;
  border-radius: 8px;
  background: #1f77d4;
  color: white;
  border: none;
  cursor: pointer;
}

footer {
  background: #081d3f;
  color: white;
  padding: 50px 24px;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  text-align: center;
  flex-wrap: wrap;
  gap: 12px;
}

footer h3 {
  margin: 0 0 8px;
}

footer p {
  margin: 0;
  color: #aac1df;
}

.fade-in {
  opacity: 0;
  transform: translateY(28px);
  transition: opacity 0.8s ease, transform 0.8s ease;
}

.fade-in.show {
  opacity: 1;
  transform: translateY(0);
}

@media (max-width: 960px) {
  nav {
    padding: 18px 20px;
    flex-wrap: wrap;
    gap: 12px;
  }

  .services-bar {
    margin-top: 14px;
  }
}

@media (max-width: 768px) {
  header::before {
    background-position: top center;
  }

  .hero {
    min-height: 70vh;
    padding: 0 16px;
  }

  nav ul {
    flex-wrap: wrap;
    justify-content: center;
  }

  .section {
    padding: 55px 20px;
  }

  footer {
    justify-content: center;
    text-align: center;
  }

  .chat-container {
    height: 60vh;
  }
}

/* Chat Styles */
.chat-container {
  max-width: 700px;
  margin: 24px auto;
  background: white;
  border-radius: 16px;
  border: 1px solid #e3ecf9;
  box-shadow: 0 14px 30px rgba(8, 30, 67, 0.1);
  display: flex;
  flex-direction: column;
  height: 70vh;
  overflow: hidden;
}

.chat-messages {
  flex: 1;
  overflow-y: auto;
  padding: 20px;
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.chat-messages::-webkit-scrollbar {
  width: 6px;
}

.chat-messages::-webkit-scrollbar-track {
  background: #f1f5fb;
}

.chat-messages::-webkit-scrollbar-thumb {
  background: #2d8dfa;
  border-radius: 3px;
}

.message {
  padding: 12px 16px;
  border-radius: 12px;
  max-width: 85%;
  word-wrap: break-word;
  line-height: 1.5;
}

.user-message {
  background: #2d8dfa;
  color: white;
  align-self: flex-end;
  border-bottom-right-radius: 4px;
}

.ai-message {
  background: #f0f5fb;
  color: #0f2140;
  align-self: flex-start;
  border-bottom-left-radius: 4px;
  border: 1px solid #e3ecf9;
}

.ai-message.typing {
  font-style: italic;
  color: #5a6b8a;
}

.typing-dots {
  display: inline-block;
}

.typing-dots::after {
  content: '.';
  animation: dots 1.5s infinite;
}

@keyframes dots {
  0% { content: '.'; }
  33% { content: '..'; }
  66% { content: '...'; }
}

.ai-message.error {
  background: #fee;
  color: #c33;
  border-color: #fcc;
}

.welcome-message {
  background: linear-gradient(135deg, #2d8dfa 0%, #1a6ed6 100%);
  color: white !important;
  border: none !important;
  font-weight: 500;
  line-height: 1.6;
  padding: 16px 14px;
}

.chat-input-container {
  display: flex;
  gap: 10px;
  padding: 16px;
  border-top: 1px solid #e3ecf9;
  background: #f8fbff;
}

#message-input {
  flex: 1;
  padding: 12px 14px;
  border: 1px solid #cbe1f9;
  border-radius: 8px;
  font-size: 14px;
  font-family: inherit;
  resize: none;
}

#message-input:focus {
  outline: none;
  border-color: #2d8dfa;
  box-shadow: 0 0 0 3px rgba(45, 141, 250, 0.1);
}

.chat-input-container button {
  padding: 12px 20px;
  background: #2d8dfa;
  color: white;
  border: none;
  border-radius: 8px;
  font-weight: 600;
  cursor: pointer;
  transition: background 0.2s ease;
}

.chat-input-container button:hover {
  background: #1a6ed6;
}

.chat-input-container button:active {
  transform: scale(0.98);
}
