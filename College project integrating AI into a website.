  <div class="carousel-wrapper">
    <div class="carousel-track">
      <div class="carousel-item"><img src="logo1.png" alt="Marca 1"></div>
      <div class="carousel-item"><img src="logo2.png" alt="Marca 2"></div>
      <div class="carousel-item"><img src="logo3.png" alt="Marca 3"></div>
      <div class="carousel-item"><img src="logo4.png" alt="Marca 4"></div>
      <div class="carousel-item"><img src="logo5.png" alt="Marca 5"></div>
      <div class="carousel-item"><img src="logo6.png" alt="Marca 6"></div>
      <div class="carousel-item"><img src="logo1.png" alt="Marca 1"></div>
      <div class="carousel-item"><img src="logo2.png" alt="Marca 2"></div>
      <div class="carousel-item"><img src="logo3.png" alt="Marca 3"></div>
      <div class="carousel-item"><img src="logo4.png" alt="Marca 4"></div>
      <div class="carousel-item"><img src="logo5.png" alt="Marca 5"></div>
