}

.dark-section h2 {
  color: #f8fcff;
}

.newsletter {
  display: flex;
  justify-content: center;
  gap: 10px;
  margin-top: 22px;
  flex-wrap: wrap;
}

.logo-carousel {
  padding: 60px 24px;
  background: #f2f6fb; /* mesmo fundo do body */
}

.service-home {
  background: #ffffff;
  padding: 60px 32px;
  margin: 0 auto;
}

.service-home-container {
